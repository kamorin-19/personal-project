# ── API ──────────────────────────────────────────────
# 開発時: Vite proxy 経由 (vite.config.ts の proxy 設定と合わせること)
PUBLIC_API_URL=http://localhost:5173/api

# 本番時
# PUBLIC_API_URL=https://api.example.com

# ── Google OAuth2 ─────────────────────────────────────
# Google Cloud Console で取得 (OAuth 2.0 クライアント ID)
PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Cloud Console で取得 (クライアントシークレット) — サーバーサイドのみ
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Cloud Console の「承認済みのリダイレクト URI」と完全一致させること
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# ── セッション ────────────────────────────────────────
# 32バイト以上のランダム文字列 (python -c "import secrets; print(secrets.token_hex(32))")
# FastAPI 側の JWT_SECRET_KEY と同じ値を設定すること
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── バックエンド (サーバーサイド直接通信) ──────────────
# Docker 環境: http://backend:8000
# ローカル実行: http://localhost:8000
BACKEND_URL=http://localhost:8000
